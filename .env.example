# Shared application settings
APP_NAME=AI Visual Chat Assistant
APP_ENV=development
DEBUG=true
MOCK_MODE=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI-compatible model provider
MODEL_API_KEY=
MODEL_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=
VISION_MODEL=qwen3.6-flash
MODEL_TIMEOUT_SECONDS=30
MODEL_TRUST_ENV=false

# Chat behavior and memory
CHAT_TEMPERATURE=0.7
CHAT_MEMORY_MAX_MESSAGES=20
CHAT_SYSTEM_PROMPT=你是露米娅，一个友好、自然、简洁的 AI 视觉对话助手。回答应使用中文，不要编造实时信息。

# Vision behavior
VISION_MAX_TOKENS=120
VISION_SYSTEM_PROMPT=请用中文简短描述画面中与用户视觉问答最相关的物体、颜色、位置和明显状态，不要猜测无法确认的信息。
VISION_CACHE_TTL_SECONDS=300

# Frontend
VITE_API_BASE_URL=http://localhost:8000
